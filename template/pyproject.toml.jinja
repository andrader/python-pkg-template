[project]
name = "{{ project_name|lower|replace(' ', '-') }}"
version = "0.1.0"
description = "{{ project_description }}"
readme = "README.md"
requires-python = ">=3.12"
authors = [
    { name = "{{ author_name }}", email = "{{ author_email }}" }
]
dependencies = [ {% if include_cli %}"typer>=0.12.0"{% endif %} ]

[project.urls]
Homepage = "https://github.com/{{ github_username }}/{{ project_name|lower|replace(' ', '-') }}"
Issues = "https://github.com/{{ github_username }}/{{ project_name|lower|replace(' ', '-') }}/issues"
Repository = "https://github.com/{{ github_username }}/{{ project_name|lower|replace(' ', '-') }}"

{% if include_cli %}
[project.scripts]
{{ project_name|lower|replace(' ', '-') }} = "{{ package_name }}.main:app"
{% endif %}

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ package_name }}"]

[dependency-groups]
dev = [
    "pytest>=8.0.0",
    "ruff>=0.3.0",
    {% if include_ty %}"ty>=0.0.29",{% endif %}
    "commitizen>=4.1.0",
    {% if include_semantic_release %}"python-semantic-release>=9.0.0",{% endif %}
    "pre-commit>=4.0.0",
    {% if include_docs %}
    "mkdocs>=1.6.1",
    "mkdocstrings[python]>=1.0.4",
    "mkdocs-material>=9.7.6",
    {% endif %}
]

[tool.pytest.ini_options]
pythonpath = ["src"]
testpaths = ["tests"]

[tool.commitizen]
name = "cz_conventional_commits"
version_provider = "pep621"
version = "0.1.0"
update_changelog_on_bump = true

{% if include_semantic_release %}
[tool.semantic_release]
version_toml = ["pyproject.toml:project.version"]
build_command = "python -m pip install uv && uv build"
upload_to_pypi = false
upload_to_release = true

[tool.semantic_release.branches.main]
match = "main"

[tool.semantic_release.changelog]
changelog_file = "CHANGELOG.md"
{% endif %}

[tool.ruff]
exclude = ["templates"]

{% if include_ty %}
[tool.ty.src]
include = ["src", "tests"]
exclude = ["templates/"]
{% endif %}
